# ---------------------------------------------------------------------------
# Multi-Agent Recruitment Crew -- environment configuration
# Copy this file to .env and fill in your values.
# ---------------------------------------------------------------------------

# --- LLM Provider -----------------------------------------------------------
# Option A: OpenAI directly
OPENAI_API_KEY=sk-your-openai-key-here

# Option B: OpenRouter (OpenAI-compatible). Set USE_OPENROUTER=true to enable.
USE_OPENROUTER=false
OPENROUTER_API_KEY=sk-or-your-openrouter-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Model to use (e.g. gpt-4o-mini, gpt-4o, openai/gpt-4o-mini via OpenRouter)
MODEL_NAME=gpt-4o-mini
MODEL_TEMPERATURE=0.2
LLM_TIMEOUT_SECONDS=60

# --- Verification / retry behavior ------------------------------------------
BORDERLINE_LOW=2.8
BORDERLINE_HIGH=3.4
MAX_RETRIES=3

# --- Server settings ----------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
BACKEND_URL=http://localhost:8000

# --- Misc -----------------------------------------------------------------------
MAX_PDF_SIZE_MB=10
LOG_LEVEL=INFO
